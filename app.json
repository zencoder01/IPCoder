{
  "expo": {
    "name": "IPCoder",
    "slug": "ipcoder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ipcoder-logo.jpg",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/ipcoder-logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ipcoder-logo.jpg",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
